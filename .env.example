# Neon PostgreSQL connection string
# Get yours at https://console.neon.tech
#
# Use the "development" branch connection string for local dev (.env.local).
# Use the "production" branch connection string in Vercel production env vars.
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# Auth.js
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
ALLOWED_EMAILS=""
# Admin emails receive access to `/admin/*`. Use a comma-separated list, e.g. "owner@example.com,manager@example.com".
# Leave empty to keep all users as cashiers.
ADMIN_EMAILS=""

# Admin PIN for restricted access (Products, Cash Reconciliation)
NEXT_PUBLIC_ADMIN_PIN="1234"

# Set to "true" to bypass Google login for local dev, CI, or Vercel Preview only.
# This bypass is disabled for Vercel production deployments and any non-Vercel runtime with NODE_ENV="production".
# AUTH_BYPASS=true
GOOGLE_API_KEY=""

# LangGraph insights agent (local dev only — see langgraph/.env.example for the agent's own env)
# URL where `bun run agent:dev` serves the graph (default: http://localhost:8123).
LANGGRAPH_DEPLOYMENT_URL="http://localhost:8123"
# Set to "true" to show the Copilot sidebar in the admin dashboard.
# Leave unset/false in production until a hosting target is chosen.
NEXT_PUBLIC_COPILOT_ENABLED="false"
