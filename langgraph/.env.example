# Copy this file to langgraph/.env and fill in your values.
# langgraph/.env is gitignored — never commit real secrets.

DATABASE_URL="postgresql://..."
GOOGLE_API_KEY=""

# Store display name used in the insights agent system prompt (defaults to "Papelería Luna")
# NEXT_PUBLIC_STORE_NAME="Papelería Luna"

# Optional: LangSmith tracing
# LANGSMITH_API_KEY=""
# LANGSMITH_TRACING="true"
